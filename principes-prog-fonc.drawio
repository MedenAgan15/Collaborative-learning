        <mxCell id="tkEypK4Vdgj_0lDnjImC-8" parent="tkEypK4Vdgj_0lDnjImC-7" style="text;whiteSpace=wrap;html=1;" value="Chaque fonction doit avoir un but unique : celui-ci doit être à la fois “simple” et “générique”." vertex="1">
