        <mxCell id="tkEypK4Vdgj_0lDnjImC-12" parent="1" style="swimlane;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="La composition (flux de données)" vertex="1">
