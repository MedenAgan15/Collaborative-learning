        </mxCell>
        <mxCell id="tkEypK4Vdgj_0lDnjImC-4" parent="tkEypK4Vdgj_0lDnjImC-3" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="La sortie de ces fonctions ne dépend que de l&#39;entrée (&quot;transparence référentielle&quot;) =&amp;gt; absence d&#39;effets de bord" vertex="1">
